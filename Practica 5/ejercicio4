//4.a) 
class A {
    static int s_a=0;
    static A() {
    s_a++;
    }
    public A() {
        s_a++;
    }
}
// La definición es correcta. 

// 4b)
class A {
    static int s_a = 0;
    public static A() {
        s_a++;
    }
    A() {
        s_a++;
    }
}
// Incorrecto, el constructor estático debería ser privado (no pueden tener modificadores de acceso)

// 4c)
class A {
    static int s_a = 0;
    static A(int a) {
        s_a=a;
    }
    A(int a) {
        s_a = a;
    }
}
// Incorrecto, el contructor estático no puede recibir parámetros

// 4d)
class A {
    static int s_a = 0;
    int a = 0;
    static A() {
        s_a = 30;
    }
    A(int a) {
        s_a = a;
        this.a = a;
    }
}
// Incorrecto, el constructor de instancia A, al no anteponerle el public el compilador asume que es privado, lo cual no se podria usar ese constructor.

// 4e)
class A {
    static int s_a = 0;
    int a = 0;
    static A() {
        a = 30;
    }
    A(int a) {
        a = s_a;
    }
}
// Incorrecto